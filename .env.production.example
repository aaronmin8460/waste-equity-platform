# Production environment template — PLACEHOLDERS ONLY. Never commit .env.production.
#
# Copy to .env.production on the server and fill in real values:
#   cp .env.production.example .env.production
# Generate a strong database password (do NOT reuse the dev default):
#   openssl rand -base64 36
# Then run the guard before deploying:
#   ./scripts/deployment/check-production-env.sh .env.production
#
# The production stack reads this file:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d

# --- Public origin ---
# The single public domain served over HTTPS by Caddy. Point its DNS A record
# at the server's static IP before starting the stack.
PUBLIC_DOMAIN=waste.thedayshiny.com

# ACME account email for Let's Encrypt certificate-expiry notices.
CADDY_ACME_EMAIL=admin@example.com

# --- Application ---
APP_ENV=production
TZ=Asia/Seoul

# --- Frontend API base ---
# Empty string = same-origin: the browser calls relative /api/v1/... paths that
# Caddy routes to the backend. It is baked into the frontend image at build time
# (docker-compose.prod.yml passes it as an empty build arg); leave this blank.
NEXT_PUBLIC_API_BASE_URL=

# --- CORS public origin ---
# docker-compose.prod.yml derives the backend CORS origin as https://${PUBLIC_DOMAIN}
# automatically. This variable is informational (same-origin requests need no
# CORS); override the compose value only if you serve the API from another origin.
CORS_ALLOW_ORIGINS=https://waste.thedayshiny.com

# --- Database (never exposed publicly) ---
# Use a dedicated production user and a strong generated password. The
# check-production-env.sh guard REJECTS empty values, the dev default
# "waste_equity", and this placeholder.
POSTGRES_USER=waste_equity_prod
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=waste_equity

# The backend DATABASE_URL is assembled from the POSTGRES_* values above inside
# docker-compose.prod.yml; you do NOT need to set it here.
# DATABASE_URL=postgresql+psycopg://waste_equity_prod:REPLACE_WITH_STRONG_PASSWORD@database:5432/waste_equity

# --- Backups ---
# Retention (days) for on-server production backups taken by the ops scripts.
BACKUP_RETENTION_DAYS=14
