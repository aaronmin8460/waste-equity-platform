# Copy this file to .env for local development when implementation begins.
# Do not commit real credentials or local .env files.

# Application
APP_ENV=development
APP_NAME=waste-equity-platform

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Database
DATABASE_URL=postgresql+psycopg://waste_equity:waste_equity@localhost:5432/waste_equity

# Scheduler
SCHEDULER_TIMEZONE=Asia/Seoul

# Korean public data API credentials
# Add source-specific environment variables here when approved integrations begin.
# Example naming pattern only; leave values blank until real credentials are issued.
KOREA_PUBLIC_DATA_API_KEY=
DATA_GO_KR_SERVICE_KEY=
AIR_QUALITY_API_KEY=
WEATHER_API_KEY=

# Resource Circulation Information System waste statistics API
RCIS_API_KEY=
# Non-secret USRID request parameter documented as 아이디 / user ID.
RCIS_USER_ID=
RCIS_API_BASE_URL=https://www.recycling-info.or.kr

# SGIS
SGIS_CONSUMER_KEY=
SGIS_CONSUMER_SECRET=

# AirKorea
AIRKOREA_SERVICE_KEY=

# Korea Meteorological Administration
KMA_SERVICE_KEY=

# VWorld
VWORLD_API_KEY=
VWORLD_API_DOMAIN=

# Raw response preservation
RAW_RESPONSE_STORAGE_PATH=./data/raw

# API probe samples
PROBE_SAMPLE_DIR=./data/samples
